{
  "name": "bilibili-mcp-server",
  "version": "1.0.10",
  "description": "B站 MCP 服务 — 哔哩哔哩 API 的 Model Context Protocol 封装，提供视频搜索、弹幕、字幕、评论、直播、用户信息、专栏等 22 个工具",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bilibili-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README_zh.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "bilibili",
    "b站",
    "哔哩哔哩",
    "mcp",
    "model-context-protocol",
    "bilibili-api",
    "弹幕",
    "danmaku",
    "danmu",
    "评论",
    "字幕",
    "视频",
    "直播",
    "mcp-server",
    "mcp-tools",
    "claude",
    "cursor",
    "ai",
    "npx"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Iseenope/bilibili-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/Iseenope/bilibili-mcp-server/issues"
  },
  "homepage": "https://github.com/Iseenope/bilibili-mcp-server#readme",
  "author": "Iseenope",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "~5.7.2",
    "vitest": "^4.1.10"
  }
}
